generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  phone              String         @unique
  password           String
  fullName           String
  cnic               String         @unique
  role               Role           @default(TENANT)
  trustScore         Int            @default(50)
  isVerified         Boolean        @default(false)
  isSuspended        Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  landlordAgreements Agreement[]    @relation("LandlordAgreements")
  tenantAgreements   Agreement[]    @relation("TenantAgreements")
  tenantDisputes     Dispute[]      @relation("TenantDisputes")
  listings           Listing[]
  payments           Payment[]
  reviews            Review[]
  conversation1      Conversation[] @relation("Conversation1")
  conversation2      Conversation[] @relation("Conversation2")
  messages           Message[]
}

model Listing {
  id          String        @id @default(cuid())
  title       String
  description String
  area        String
  city        String
  address     String
  type        PropertyType
  bedrooms    Int
  bathrooms   Int
  sqft        Int
  rent        Int
  deposit     Int
  status      ListingStatus @default(PENDING)
  fraudScore  Float         @default(0)
  photos      String[]
  landlordId  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  agreements  Agreement[]
  landlord    User          @relation(fields: [landlordId], references: [id])
  reviews     Review[]
}

model Agreement {
  id         String          @id @default(cuid())
  listingId  String
  tenantId   String
  landlordId String
  rent       Int
  deposit    Int
  startDate  DateTime
  endDate    DateTime
  pdfUrl     String?
  status     AgreementStatus @default(PENDING)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  landlord   User            @relation("LandlordAgreements", fields: [landlordId], references: [id])
  listing    Listing         @relation(fields: [listingId], references: [id])
  tenant     User            @relation("TenantAgreements", fields: [tenantId], references: [id])
  disputes   Dispute[]
  payments   Payment[]
}

model Payment {
  id            String        @id @default(cuid())
  agreementId   String
  tenantId      String
  amount        Int
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?
  receiptUrl    String?
  month         DateTime
  createdAt     DateTime      @default(now())
  agreement     Agreement     @relation(fields: [agreementId], references: [id])
  tenant        User          @relation(fields: [tenantId], references: [id])
}

model Dispute {
  id          String        @id @default(cuid())
  agreementId String
  tenantId    String
  title       String
  description String
  amount      Int?
  status      DisputeStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  agreement   Agreement     @relation(fields: [agreementId], references: [id])
  tenant      User          @relation("TenantDisputes", fields: [tenantId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  listingId String
  userId    String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Conversation {
  id             String    @id @default(cuid())
  participant1Id String
  participant2Id String
  listingId      String?
  agreementId    String?
  lastMessageAt  DateTime  @updatedAt
  createdAt      DateTime  @default(now())
  messages       Message[]
  participant1   User      @relation("Conversation1", fields: [participant1Id], references: [id])
  participant2   User      @relation("Conversation2", fields: [participant2Id], references: [id])

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  attachmentUrl  String?
  isRead         Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  message   String
  status    String   @default("new")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum Role {
  TENANT
  LANDLORD
  ADMIN
}

enum PropertyType {
  FLAT
  ROOM
  HOUSE
  STUDIO
}

enum ListingStatus {
  PENDING
  VERIFIED
  FLAGGED
  REMOVED
}

enum AgreementStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentMethod {
  JAZZCASH
  EASYPAISA
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum DisputeStatus {
  OPEN
  MEDIATION
  RESOLVED
  CLOSED
}

enum Score {
  ZERO
  ONE
  TWO
  THREE
  FOUR
  FIVE
}
