graph TD
    Tenant["Tenant User<br/>View Due Rent<br/>Pay Monthly"]
    
    PaymentFE["Payment Dashboard<br/>Amount Display<br/>Payment Methods<br/>Transaction History"]
    
    PaymentAPI["Payment Controller<br/>POST /payments<br/>PATCH /payments/:id<br/>GET /payments"]
    
    PaymentService["Payment Service<br/>Business Logic<br/>Status Management<br/>Record Keeping"]
    
    subgraph PaymentMethods["PAYMENT METHODS SUPPORTED"]
        JazzCash["JazzCash<br/>Pakistan Mobile<br/>Operator<br/>Quick Transfer"]
        
        EasyPaisa["EasyPaisa<br/>Pakistan Mobile<br/>Operator<br/>Easy Access"]
        
        BankTransfer["Bank Transfer<br/>Direct Account<br/>Government Banks<br/>Corporate Accounts"]
        
        Stripe["Stripe Integration<br/>Credit/Debit Card<br/>International<br/>Recurring Payments"]
    end
    
    subgraph PaymentFlow["PAYMENT WORKFLOW"]
        PENDING["PENDING<br/>Payment Created<br/>Awaiting Submission<br/>Not Processed"]
        
        PROCESSING["PROCESSING<br/>Sent to Gateway<br/>Verification<br/>Authorization"]
        
        COMPLETED["COMPLETED<br/>Transaction Success<br/>Funds Received<br/>Rent Applied"]
        
        FAILED["FAILED<br/>Transaction Declined<br/>Insufficient Funds<br/>Invalid Card<br/>Timeout"]
        
        REFUNDED["REFUNDED<br/>Refund Issued<br/>Manual Refund<br/>System Refund"]
    end
    
    subgraph GatewayProcessing["GATEWAY PROCESSING"]
        StripeGW["Stripe API<br/>Payment Processing<br/>Webhook Handling<br/>Charge Creation"]
        
        RazorpayGW["Razorpay API<br/>India Integration<br/>Multiple Methods<br/>Settlement"]
        
        PakGateway["Pakistan Operators<br/>JazzCash API<br/>EasyPaisa API<br/>Direct Integration"]
        
        Verification["Verification<br/>CVV Check<br/>3D Secure<br/>Fraud Detection<br/>OTP Validation"]
    end
    
    subgraph FinancialRecords["FINANCIAL RECORDS"]
        Database["Payment Database<br/>Store Payments<br/>Amount<br/>Date<br/>Status<br/>Gateway Reference"]
        
        ReceiptGeneration["Receipt Generation<br/>PDF Format<br/>Invoice Number<br/>Details<br/>Signature"]
        
        Reporting["Financial Reports<br/>Monthly Summaries<br/>Landlord Earnings<br/>Tenant Payments<br/>Refund Tracking"]
    end
    
    NotificationSvc["Notification Service<br/>Email Receipts<br/>SMS Confirmation<br/>Alerts<br/>Reminders"]
    
    Landlord["Landlord User<br/>View Receipts<br/>Track Earnings"]
    
    DisputeModule["Dispute Module<br/>Link Payments<br/>Refund Disputes<br/>Payment Conflicts"]
    
    Tenant -->|Initiate Payment| PaymentFE
    PaymentFE -->|Select Method| JazzCash
    PaymentFE -->|Select Method| EasyPaisa
    PaymentFE -->|Select Method| BankTransfer
    PaymentFE -->|Select Method| Stripe
    
    JazzCash -->|Send Request| PaymentAPI
    EasyPaisa -->|Send Request| PaymentAPI
    BankTransfer -->|Send Request| PaymentAPI
    Stripe -->|Send Request| PaymentAPI
    
    PaymentAPI -->|Create Record| PaymentService
    PaymentService -->|New Payment| PENDING
    
    PENDING -->|Submit to Gateway| PROCESSING
    
    PROCESSING -->|Route to Gateway| StripeGW
    PROCESSING -->|Route to Gateway| RazorpayGW
    PROCESSING -->|Route to Gateway| PakGateway
    
    StripeGW -->|Verify Details| Verification
    RazorpayGW -->|Verify Details| Verification
    PakGateway -->|Verify Details| Verification
    
    Verification -->|Success| COMPLETED
    Verification -->|Failure| FAILED
    
    COMPLETED -->|Store Transaction| Database
    COMPLETED -->|Generate Receipt| ReceiptGeneration
    COMPLETED -->|Generate Confirmation| NotificationSvc
    
    FAILED -->|Store Failed Record| Database
    FAILED -->|Notify Tenant| NotificationSvc
    FAILED -->|Show Retry Option| PaymentFE
    
    ReceiptGeneration -->|Email Receipt| NotificationSvc
    NotificationSvc -->|Send to Tenant| Tenant
    NotificationSvc -->|Send to Landlord| Landlord
    
    Database -->|Generate Reports| Reporting
    Reporting -->|Monthly Summary| Landlord
    
    COMPLETED -->|Link if Dispute| DisputeModule
    FAILED -->|May Create Dispute| DisputeModule
    
    PaymentService -->|Update Record| Database
    
    style PaymentMethods fill:#e8f5e9
